# Copy this file to .env and fill in your values.
# Load with: export $(grep -v '^#' .env | xargs)
# Or use python-dotenv if you prefer.

# Required — GitHub Personal Access Token (classic or fine-grained)
# Scopes needed: read:user, read:org (no write permissions required)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional — Anthropic API key for structured CV parsing
# Without this, the tool still downloads and extracts raw text,
# but won't produce structured JSON (education, experience, skills).
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here
